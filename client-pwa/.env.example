# ============================================================
# DESVARE — PWA Cliente (.env.example)
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env al repositorio (está en .gitignore).
# ============================================================

# ------------------------------------------------------------
# Backend URL
# DEV  → http://localhost:5000
# PROD → https://api.desvare.app
# ------------------------------------------------------------
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ------------------------------------------------------------
# Mapbox (mapa interactivo)
# Obtén tu token en: https://account.mapbox.com/
# ------------------------------------------------------------
VITE_MAPBOX_TOKEN=

# ------------------------------------------------------------
# Google Maps (geocoding / búsqueda de direcciones)
# Obtén tu key en: https://console.cloud.google.com/
# Activa: Places API, Geocoding API
# ------------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------
# Firebase (notificaciones push web)
# Obtén los valores en: Firebase Console → Configuración del proyecto
# La VAPID_KEY está en: Mensajería en la nube → Certificados web push
# ------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ------------------------------------------------------------
# Sentry (monitoreo de errores — opcional en dev)
# Obtén el DSN en: https://sentry.io → tu proyecto → Settings → DSN
# ------------------------------------------------------------
VITE_SENTRY_DSN=
