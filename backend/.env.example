# Configuración del servidor
PORT=5001
NODE_ENV=production

# MongoDB Atlas
# Reemplaza con tu propia cadena de conexión de MongoDB Atlas.
# NUNCA pongas credenciales reales aquí (este archivo SÍ se sube a git).
MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@CLUSTER.mongodb.net/desvare?retryWrites=true&w=majority

# DigitalOcean Spaces
DO_SPACES_KEY=tu_spaces_key_aqui
DO_SPACES_SECRET=tu_spaces_secret_aqui
DO_SPACES_ENDPOINT=fra1.digitaloceanspaces.com
DO_SPACES_BUCKET=desvare
DO_SPACES_REGION=fra1

# Firebase
FIREBASE_PROJECT_ID=desvare-production
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Twilio Verify (para OTP)
TWILIO_ACCOUNT_SID=tu_twilio_account_sid
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=tu_twilio_verify_service_sid

# Modo desarrollo para OTP (true = usa código fijo 123456, false = usa Twilio real)
# Activar si tienes cuenta Trial de Twilio y no quieres verificar números
# IMPORTANTE: Cambiar a 'false' en producción
TWILIO_DEV_MODE=true

# JWT Secret
# Genera uno aleatorio y fuerte. Ej: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# NUNCA pongas el secreto real aquí (este archivo SÍ se sube a git).
JWT_SECRET=genera_un_secreto_aleatorio_y_largo

# VAPID Keys para Web Push nativo (iOS Safari)
# Genera con: node -e "const w = require('web-push'); const k = w.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=tu_vapid_public_key
VAPID_PRIVATE_KEY=tu_vapid_private_key

# URLs permitidas (CORS) - PRODUCCIÓN + LOCALHOST para Driver App
CLIENT_URL=https://desvare.app,https://www.desvare.app,http://localhost:5173
DRIVER_URL=https://driver.desvare.app,http://localhost:8100,http://localhost:5174,capacitor://localhost,ionic://localhost
ADMIN_URL=https://admin.desvare.app,http://localhost:5176
