# ============================================================
# DESVARE — App Conductores (.env.example)
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env al repositorio (está en .gitignore).
# ============================================================

# ------------------------------------------------------------
# Backend URL
# DEV  → http://localhost:5000
# PROD → https://api.desvare.app
# ------------------------------------------------------------
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ------------------------------------------------------------
# Mapbox (mapa interactivo)
# Obtén tu token en: https://account.mapbox.com/
# ------------------------------------------------------------
VITE_MAPBOX_TOKEN=

# ------------------------------------------------------------
# Modo desarrollo
# En true: omite permisos nativos de Capacitor al probar en browser.
# En PROD o al compilar el APK: debe ser false o estar ausente.
# ------------------------------------------------------------
VITE_DEV_MODE=true

# ------------------------------------------------------------
# Sentry (monitoreo de errores — opcional en dev)
# Obtén el DSN en: https://sentry.io → tu proyecto → Settings → DSN
# ------------------------------------------------------------
VITE_SENTRY_DSN=
